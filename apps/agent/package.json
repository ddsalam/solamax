{
  "name": "@solamax/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "solamax-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dry-run": "tsx src/index.ts --dry-run --once",
    "test-connection": "tsx src/index.ts --test-connection"
  },
  "dependencies": {
    "@solamax/shared": "workspace:*",
    "mysql2": "^3.11.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
