{
  "name": "@solamax/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "solamax-agent": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dry-run": "tsx src/index.ts --dry-run --once",
    "test-connection": "tsx src/index.ts --test-connection",
    "probe": "tsx src/index.ts --probe",
    "probe:schema": "tsx src/index.ts --probe --discovery",
    "probe2": "tsx src/index.ts --probe2",
    "probe3": "tsx src/index.ts --probe3",
    "probe4": "tsx src/index.ts --probe4",
    "probe5": "tsx src/index.ts --probe5",
    "probe6": "tsx src/index.ts --probe6",
    "probe7": "tsx src/index.ts --probe7",
    "probe8": "tsx src/index.ts --probe8",
    "bundle": "node scripts/bundle.mjs"
  },
  "dependencies": {
    "@solamax/shared": "workspace:*",
    "mysql": "^2.18.1",
    "mysql2": "^3.11.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mysql": "^2.15.27",
    "@types/node": "^22.7.4",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  }
}
