// Skema Cloud SQL Postgres — mirror ARCHITECTURE.md §3 (TERKUNCI by verifikasi
// 2026-06-11). Detail tanpa PRI di MySQL → surrogate id + UNIQUE natural key.

generator client {
  provider        = "prisma-client-js"
  // native = dev Mac; debian-openssl-3.0.x = node:22-slim (bookworm) di Cloud Run.
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // public = mirror data EasyMax (read-only utk app); app = auth/kontrol RBAC.
  schemas  = ["app", "public"]
}

model Unit {
  unitId     Int      @id @map("unit_id") @db.SmallInt
  code       String   @unique
  name       String
  apiKeyHash String   @unique @map("api_key_hash")
  timezone   String   @default("Asia/Pontianak")
  active     Boolean  @default(true)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  tenantId   String?  @map("tenant_id") @db.Uuid // pemilik SPBU (multi-tenant)

  tenant    Tenant?    @relation(fields: [tenantId], references: [id])
  userUnits UserUnit[]

  @@map("unit")
  @@schema("public")
}

model SyncState {
  unitId        Int       @map("unit_id") @db.SmallInt
  domain        String
  lastWatermark DateTime? @map("last_watermark") @db.Timestamptz()
  lastRunAt     DateTime? @map("last_run_at") @db.Timestamptz()
  lastRowCount  Int?      @map("last_row_count")

  @@id([unitId, domain])
  @@map("sync_state")
  @@schema("public")
}

model SalesHeader {
  unitId     Int      @map("unit_id") @db.SmallInt
  ckdjualbbm String   @db.Char(15)
  dtgljual   DateTime @db.Date
  nshift     Int?     @db.SmallInt
  vcket      String?

  @@id([unitId, ckdjualbbm])
  @@index([unitId, dtgljual])
  @@map("sales_header")
  @@schema("public")
}

model SalesDetail {
  id          BigInt   @id @default(autoincrement())
  unitId      Int      @map("unit_id") @db.SmallInt
  ckdjualbbm  String   @db.Char(15)
  ckdnozzle   String   @db.Char(5)
  nurut       Int
  nstandawal  Decimal? @db.Decimal
  nstandakhir Decimal? @db.Decimal
  nvolume     Decimal? @db.Decimal
  nhargajual  Decimal? @db.Decimal
  nsubtotal   Decimal? @db.Decimal
  ckdbbm      String?  @db.Char(5)
  ckdtangki   String?  @db.Char(5)
  vcopeator   String?
  dtgljam     DateTime @db.Timestamptz()
  subah       Int?     @db.SmallInt
  sedit       Int?     @db.SmallInt
  ingestedAt  DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@unique([unitId, ckdjualbbm, ckdnozzle, nurut])
  @@index([unitId, dtgljam])
  @@map("sales_detail")
  @@schema("public")
}

model CashHeader {
  unitId     Int      @map("unit_id") @db.SmallInt
  ckdkb      String   @db.Char(15)
  dtgl       DateTime @db.Date
  vcket      String?
  sjnstrans  Int?     @db.SmallInt
  ntotal     Decimal? @db.Decimal
  vcref      String?
  ctmpkas    String?
  sbatal     Int?     @db.SmallInt
  ingestedAt DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@id([unitId, ckdkb])
  @@index([unitId, dtgl])
  @@map("cash_header")
  @@schema("public")
}

model CashDetail {
  id         BigInt   @id @default(autoincrement())
  unitId     Int      @map("unit_id") @db.SmallInt
  ckdkb      String   @db.Char(15)
  ckdperk    String?  @db.Char(8)
  njumlah    Decimal? @db.Decimal
  ingestedAt DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@unique([unitId, ckdkb, ckdperk])
  @@map("cash_detail")
  @@schema("public")
}

model Opname {
  id          BigInt    @id @default(autoincrement())
  unitId      Int       @map("unit_id") @db.SmallInt
  ckdopnbbm   String    @db.Char(15)
  ckdtangki   String    @db.Char(5)
  ckdbbm      String?   @db.Char(5)
  dtaglopn    DateTime? @db.Date
  nstockbk    Decimal?  @db.Decimal
  nstockop    Decimal?  @db.Decimal
  nvolselisih Decimal?  @db.Decimal
  dtgljam     DateTime  @db.Timestamptz()
  sbatal      Int?      @db.SmallInt
  ingestedAt  DateTime  @default(now()) @map("ingested_at") @db.Timestamptz()

  @@unique([unitId, ckdopnbbm, ckdtangki])
  @@index([unitId, dtgljam])
  @@map("opname")
  @@schema("public")
}

// Penebusan DO — header (tr_htebus). UPSERT by (unit_id, ckdtbs). Watermark
// DTGLTBS (date). Basis kolom "Penebusan DO" + running-balance DO Awal/Sisa.
model TebusHeader {
  unitId     Int      @map("unit_id") @db.SmallInt
  ckdtbs     String   @db.Char(15)
  dtgltbs    DateTime @db.Date
  cnoso      String?  @db.Char(20)
  sbatal     Int?     @db.SmallInt
  ingestedAt DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@id([unitId, ckdtbs])
  @@index([unitId, dtgltbs])
  @@map("tebus_header")
  @@schema("public")
}

// Penebusan DO — detail per produk (tr_dtebus). Grain (unit_id, ckdtbs, ckdbbm).
// NSISA = kolom mati (=NVOLUME) → tak di-sync. Surrogate id + unique utk UPSERT.
model TebusDetail {
  id         BigInt   @id @default(autoincrement())
  unitId     Int      @map("unit_id") @db.SmallInt
  ckdtbs     String   @db.Char(15)
  ckdbbm     String?  @db.Char(5)
  nvolume    Decimal? @db.Decimal
  ingestedAt DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@unique([unitId, ckdtbs, ckdbbm])
  @@map("tebus_detail")
  @@schema("public")
}

// Tera/kalibrasi nozzle (tabel EasyMax `tera`). Sumber kolom "Tera (L)" +
// komponen Penjualan_BERSIH (jual KOTOR − tera) di Gain/Losses harian. Watermark
// TanggalJam (datetime). Surrogate id + UNIQUE (unit_id, tanggaljam, no_nozzle)
// → idempoten saat re-pull window. ckdbbm di-resolve di agent (join MySQL ke
// tm_tangki/tm_bbm by name). Identifier mentah (no_nozzle/id_pompa/sa_tangki)
// disimpan untuk audit + kunci unik.
model Tera {
  id           BigInt   @id @default(autoincrement())
  unitId       Int      @map("unit_id") @db.SmallInt
  businessDate DateTime @map("business_date") @db.Date
  tanggaljam   DateTime @db.Timestamptz()
  noNozzle     String?  @map("no_nozzle") @db.VarChar(4)
  idPompa      Int?     @map("id_pompa") @db.SmallInt
  saTangki     Int?     @map("sa_tangki") @db.SmallInt
  jenis        Int?     @db.SmallInt
  ckdbbm       String?  @db.Char(5)
  liter        Decimal? @db.Decimal
  total        Decimal? @db.Decimal
  ingestedAt   DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@unique([unitId, tanggaljam, noNozzle])
  @@index([unitId, businessDate])
  @@map("tera")
  @@schema("public")
}

// Tera RESMI (ledger EasyMax tr_hterra ⋈ tr_dterra). SUMBER TUNGGAL angka terra
// laporan: Rincian B + seksi TERRA + kolom "Tera (L)" Laporan + net-sales G/L
// (gross − Σ nvolume). business_date = DTGLTERRA (= DTGLJUAL jurnal tertaut).
// Full-sync agent; UPSERT by natural key (unit_id, ckdterra, ckdnozzle). Filter
// laporan sbatal=0. BEDA dari `tera` (log mentah), yang tak lagi dipakai laporan.
model TerraResmi {
  unitId       Int      @map("unit_id") @db.SmallInt
  businessDate DateTime @map("business_date") @db.Date
  ckdterra     String   @db.VarChar(15)
  ckdnozzle    String   @db.VarChar(5)
  nshift       Int?     @db.SmallInt
  ckdtangki    String?  @db.Char(5)
  ckdbbm       String?  @db.Char(5)
  nvolume      Decimal? @db.Decimal
  nharga       Decimal? @db.Decimal
  ntotal       Decimal? @db.Decimal
  dtgljam      DateTime @db.Timestamptz()
  ckdjualbbm   String?  @db.VarChar(15)
  sbatal       Int?     @db.SmallInt
  ingestedAt   DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@id([unitId, ckdterra, ckdnozzle])
  @@index([unitId, businessDate])
  @@map("terra_resmi")
  @@schema("public")
}

model Delivery {
  unitId      Int       @map("unit_id") @db.SmallInt
  ckdtrm      String    @db.Char(15)
  dtgltrm     DateTime? @db.Date
  dtgljam     DateTime  @db.Timestamptz()
  cnodo       String?
  cnoso       String?   @db.Char(20)
  nvoldo      Decimal?  @db.Decimal
  nvolreal    Decimal?  @db.Decimal
  nvolselisih Decimal?  @db.Decimal
  cnopol      String?
  vcsopir     String?
  ckdtangki   String?   @db.Char(5)
  ckdbbm      String?   @db.Char(5)
  sbatal      Int?      @db.SmallInt
  ingestedAt  DateTime  @default(now()) @map("ingested_at") @db.Timestamptz()

  @@id([unitId, ckdtrm])
  @@index([unitId, dtgljam])
  @@map("delivery")
  @@schema("public")
}

model RealTank {
  unitId      Int      @map("unit_id") @db.SmallInt
  ckdtangki   String   @db.Char(5)
  nkapasitas  Decimal? @db.Decimal
  ntinggi     Decimal? @db.Decimal
  nvolume     Decimal? @db.Decimal
  nsuhu       Decimal? @db.Decimal
  ntinggiair  Decimal? @db.Decimal
  nvolumeair  Decimal? @db.Decimal
  nstatus     Int?     @db.SmallInt
  dtanggaljam DateTime @db.Timestamptz()
  ingestedAt  DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@id([unitId, ckdtangki])
  @@map("real_tank")
  @@schema("public")
}

model Product {
  unitId   Int      @map("unit_id") @db.SmallInt
  ckdbbm   String   @db.Char(5)
  vcnmbbm  String?
  nhrgjual Decimal? @db.Decimal
  perkMap  Json?    @map("perk_map")

  @@id([unitId, ckdbbm])
  @@map("product")
  @@schema("public")
}

model Nozzle {
  unitId    Int     @map("unit_id") @db.SmallInt
  ckdnozzle String  @db.Char(5)
  ckdpompa  String? @db.Char(5)
  ckdtangki String? @db.Char(5)

  @@id([unitId, ckdnozzle])
  @@map("nozzle")
  @@schema("public")
}

model Tangki {
  unitId     Int     @map("unit_id") @db.SmallInt
  ckdtangki  String  @db.Char(5)
  ckdbbm     String? @db.Char(5)
  vcnmtangki String?

  @@id([unitId, ckdtangki])
  @@map("tangki")
  @@schema("public")
}

model Account {
  unitId   Int     @map("unit_id") @db.SmallInt
  ckdperk  String  @db.Char(8)
  vcnmperk String?
  ckdinduk String? @db.Char(8)

  @@id([unitId, ckdperk])
  @@map("account")
  @@schema("public")
}

// --- Rincian Penjualan (FASE 1b) — sumber TERKUNCI by probe (ADR-001) ---

// Deposit prabayar pelanggan (tr_deposit). UPSERT by (unit_id, ckddepo); full-sync agent.
model Deposit {
  unitId     Int      @map("unit_id") @db.SmallInt
  ckddepo    String   @db.Char(15)
  dtgl       DateTime @db.Date
  ckdplg     String?  @db.VarChar(12)
  ntotal     Decimal? @db.Decimal
  nsaldo     Decimal? @db.Decimal
  sbatal     Int?     @db.SmallInt
  vcket      String?
  ingestedAt DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@id([unitId, ckddepo])
  @@index([unitId, dtgl])
  @@map("deposit")
  @@schema("public")
}

// EDC/non-tunai (vw_edc3). Surrogate id; REPLACE per (unit_id, business_date).
// ckdkartu null = blank-card (tak terklasifikasi; di-flag di dashboard).
model Edc {
  id           BigInt   @id @default(autoincrement())
  unitId       Int      @map("unit_id") @db.SmallInt
  businessDate DateTime @map("business_date") @db.Date
  cshift       String?  @db.VarChar(1)
  tanggaljam   DateTime @db.Timestamptz()
  ckdkartu     String?  @db.Char(5)
  total        Decimal? @db.Decimal
  liter        Decimal? @db.Decimal
  jenis        Int?     @db.SmallInt
  cnotrace     String?  @db.VarChar(20)
  nonozle      String?  @db.VarChar(4)
  jrnkey       Int?
  ingestedAt   DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  // Kunci natural anti-kembar (idempotensi REPLACE bersamaan). Index FISIK dibuat
  // migrasi 0012 dengan NULLS NOT DISTINCT (ckdkartu/cnotrace sering NULL utk
  // blank-card; Prisma 5.x belum bisa mengekspresikan NULLS NOT DISTINCT → @@unique
  // di sini hanya model logis, drift NULLS sengaja & terdokumentasi). Nama index
  // SAMA → ON CONFLICT (sql.ts buildReplace) menginfer index ini.
  @@unique([unitId, businessDate, cshift, tanggaljam, nonozle, cnotrace, ckdkartu, total], map: "edc_natural_key")
  @@index([unitId, businessDate])
  @@map("edc")
  @@schema("public")
}

// Penjualan tempo pelanggan (vw_jualplg). Surrogate id; REPLACE per business_date.
model PelangganSale {
  id           BigInt   @id @default(autoincrement())
  unitId       Int      @map("unit_id") @db.SmallInt
  businessDate DateTime @map("business_date") @db.Date
  ckdplg       String?  @db.VarChar(12)
  vcnmplg      String?
  ckdjualplg   String?  @db.Char(15)
  ckdbbm       String?  @db.VarChar(5)
  nshift       Int?     @db.SmallInt
  liter        Decimal? @db.Decimal
  total        Decimal? @db.Decimal
  sbatal       Int?     @db.SmallInt
  ingestedAt   DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@index([unitId, businessDate])
  @@map("pelanggan_sale")
  @@schema("public")
}

// Penjualan voucher pelanggan (vw_usevouc). Surrogate id; REPLACE per business_date.
model VoucherSale {
  id           BigInt   @id @default(autoincrement())
  unitId       Int      @map("unit_id") @db.SmallInt
  businessDate DateTime @map("business_date") @db.Date
  ckdplg       String?  @db.VarChar(12)
  vcnmplg      String?
  ckdusevouc   String?  @db.Char(15)
  ckdbbm       String?  @db.VarChar(5)
  nshift       Int?     @db.SmallInt
  liter        Decimal? @db.Decimal
  total        Decimal? @db.Decimal
  sbatal       Int?     @db.SmallInt
  ingestedAt   DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@index([unitId, businessDate])
  @@map("voucher_sale")
  @@schema("public")
}

// Master kartu/channel EDC (tm_card). PK (unit_id, ckdcard); full-sync.
model Card {
  unitId   Int     @map("unit_id") @db.SmallInt
  ckdcard  String  @db.Char(5)
  vcnmcard String?
  ckdbank  String? @db.Char(5)
  cgl      String? @db.VarChar(8)

  @@id([unitId, ckdcard])
  @@map("card")
  @@schema("public")
}

// Buku piutang pelanggan (tr_bppiut). Ledger; full-sync, UPSERT by (unit_id, ckdbppiut).
// Saldo Piutang = Σ njumlah·sign(sjnsbp:1=+,2=−), sbatal=0, dtgl<tanggal; split via
// pelanggan_master.sjenis (Lokal 1,5 · Online 3 · 4 dikecualikan).
model Bppiut {
  unitId     Int      @map("unit_id") @db.SmallInt
  ckdbppiut  String   @db.Char(15)
  dtgl       DateTime @db.Date
  ckdplg     String?  @db.VarChar(12)
  vcref      String?  @db.VarChar(20)
  vcket      String?
  njumlah    Decimal? @db.Decimal
  sjnsbp     Int?     @db.SmallInt
  sbatal     Int?     @db.SmallInt
  ingestedAt DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@id([unitId, ckdbppiut])
  @@index([unitId, dtgl])
  @@index([unitId, ckdplg])
  @@map("bppiut")
  @@schema("public")
}

// Buku hutang pelanggan (tr_bphut). Ledger; full-sync, UPSERT by (unit_id, ckdbphut).
// Saldo Hutang Lokal = −Σ njumlah·sign(sjnsbp:2=+,1=−), sbatal=0, dtgl<tanggal.
model Bphut {
  unitId     Int      @map("unit_id") @db.SmallInt
  ckdbphut   String   @db.Char(15)
  dtgl       DateTime @db.Date
  ckdplg     String?  @db.VarChar(12)
  vcref      String?  @db.VarChar(20)
  vcket      String?
  njumlah    Decimal? @db.Decimal
  sjnsbp     Int?     @db.SmallInt
  sbatal     Int?     @db.SmallInt
  ingestedAt DateTime @default(now()) @map("ingested_at") @db.Timestamptz()

  @@id([unitId, ckdbphut])
  @@index([unitId, dtgl])
  @@map("bphut")
  @@schema("public")
}

// Master pelanggan AR (tm_plg). PK (unit_id, ckdplg); full-sync. `sjenis` =
// diskriminator Lokal/Online utk Saldo Piutang. (Tabel `pelanggan` = kartu RFID.)
model PelangganMaster {
  unitId  Int     @map("unit_id") @db.SmallInt
  ckdplg  String  @db.Char(12)
  vcnmplg String?
  sjenis  Int?    @db.SmallInt
  saktif  Int?    @db.SmallInt

  @@id([unitId, ckdplg])
  @@map("pelanggan_master")
  @@schema("public")
}

// ===========================================================================
// Schema `app` — auth (Auth.js v5 / @auth/pg-adapter) + RBAC multi-tenant.
// Tabel Auth.js dipetakan VERBATIM sesuai DDL adapter (id serial int, kolom
// camelCase ber-quote, TANPA FK/unique tambahan) demi NOL DRIFT. FK & integritas
// hanya di tabel milik kita (tenant/membership/user_unit). Lihat AUTH-RBAC-DESIGN.md.
// ===========================================================================

/// Auth.js: identitas user (dikelola adapter). JANGAN ubah nama kolom/tipe.
model User {
  id            Int       @id @default(autoincrement())
  name          String?   @db.VarChar(255)
  email         String?   @db.VarChar(255)
  emailVerified DateTime? @map("emailVerified") @db.Timestamptz()
  image         String?

  memberships Membership[] // relasi milik kita (FK di sisi membership)

  @@map("users")
  @@schema("app")
}

/// Auth.js: akun OAuth tertaut (Google). Verbatim adapter.
model AuthAccount {
  id                Int     @id @default(autoincrement())
  userId            Int     @map("userId")
  type              String  @db.VarChar(255)
  provider          String  @db.VarChar(255)
  providerAccountId String  @map("providerAccountId") @db.VarChar(255)
  refresh_token     String?
  access_token      String?
  expires_at        BigInt?
  id_token          String?
  scope             String?
  session_state     String?
  token_type        String?

  @@map("accounts")
  @@schema("app")
}

/// Auth.js: sesi DB (revocation seketika). Verbatim adapter.
model AuthSession {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("userId")
  expires      DateTime @db.Timestamptz()
  sessionToken String   @map("sessionToken") @db.VarChar(255)

  @@map("sessions")
  @@schema("app")
}

/// Auth.js: token verifikasi. Verbatim adapter (PK gabungan, tanpa id).
model VerificationToken {
  identifier String
  token      String
  expires    DateTime @db.Timestamptz()

  @@id([identifier, token])
  @@map("verification_token")
  @@schema("app")
}

/// Perusahaan (multi-tenant). Pilot: 1 baris (SolaGroup).
model Tenant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String   @unique
  status    String   @default("active") // active | suspended
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  memberships Membership[]
  units       Unit[]

  @@map("tenant")
  @@schema("app")
}

/// OTORISASI: user ⇒ tenant + role. tenant_id NULL = super_admin (lintas-tenant).
model Membership {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         Int      @map("user_id")
  tenantId       String?  @map("tenant_id") @db.Uuid
  role           String // super_admin | admin_perusahaan | direksi | pengawas
  status         String   @default("active") // active | invited | disabled
  invitedByEmail String?  @map("invited_by_email")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  units  UserUnit[]

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@map("membership")
  @@schema("app")
}

/// Scope unit utk pengawas (direksi/admin = semua unit tenant → tanpa baris).
// Manual-entry pengawas (Pendapatan Lain / Pengeluaran). Identitas = id uuid;
// `urut` ordering biasa (BUKAN bagian unique). Audit void: voided_by + voided_at.
enum ManualEntrySection {
  pendapatan_lain
  pengeluaran
  setoran_tunai

  @@map("manual_entry_section")
  @@schema("app")
}

model ManualEntry {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId          Int                @map("unit_id") @db.SmallInt
  businessDate    DateTime           @map("business_date") @db.Date
  section         ManualEntrySection
  urut            Int                @default(0)
  keterangan      String
  amount          Decimal            @db.Decimal(17, 2)
  void            Boolean            @default(false)
  createdByUserId Int                @map("created_by_user_id")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime           @default(now()) @map("updated_at") @db.Timestamptz()
  voidedByUserId  Int?               @map("voided_by_user_id")
  voidedAt        DateTime?          @map("voided_at") @db.Timestamptz()

  @@index([unitId, businessDate, section])
  @@map("manual_entry")
  @@schema("app")
}

// Usulan Penebusan SO (input pengawas → Keuangan). 3 kolom manual per produk per
// tanggal; "awal hari" (Sisa Stock/DO) TIDAK disimpan (carry-forward D−1 dihitung
// ulang di dashboard). VOID-only + audit. `status` draft→diajukan (informasional,
// pengawas-driven). Satu baris aktif per (unit,tanggal,produk) — partial unique.
model UsulanSo {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId           Int       @map("unit_id") @db.SmallInt
  businessDate     DateTime  @map("business_date") @db.Date
  productKey       String    @map("product_key")
  penerimaanHari   Decimal   @default(0) @map("penerimaan_hari") @db.Decimal(14, 2)
  permintaanBesok  Decimal   @default(0) @map("permintaan_besok") @db.Decimal(14, 2)
  usulanPenebusan  Decimal   @default(0) @map("usulan_penebusan") @db.Decimal(14, 2)
  status           String    @default("draft")
  void             Boolean   @default(false)
  createdByUserId  Int       @map("created_by_user_id")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz()
  voidedByUserId   Int?      @map("voided_by_user_id")
  voidedAt         DateTime? @map("voided_at") @db.Timestamptz()

  @@index([unitId, businessDate])
  @@map("usulan_so")
  @@schema("app")
}

model UserUnit {
  membershipId String @map("membership_id") @db.Uuid
  unitId       Int    @map("unit_id") @db.SmallInt

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  unit       Unit       @relation(fields: [unitId], references: [unitId], onDelete: Cascade)

  @@id([membershipId, unitId])
  @@map("user_unit")
  @@schema("app")
}

/// Jejak audit append-only untuk aksi /admin (grant/revoke akses). Migration 0017.
/// dashboard_app: SELECT+INSERT saja (UPDATE/DELETE dicabut → tak bisa ditulis-ulang).
model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId Int      @map("actor_user_id")
  actorEmail  String?  @map("actor_email")
  action      String
  target      String?
  detail      Json?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@index([createdAt])
  @@index([action])
  @@map("audit_log")
  @@schema("app")
}
